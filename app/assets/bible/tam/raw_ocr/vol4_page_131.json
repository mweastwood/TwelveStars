        542,
        177,
        722,
        195
      ],
      "score": 0.9977757930755615
    },
    {
      "text": "y plañireis, mientras el mundo se regocijará: os contrista-",
      "box": [
        75,
        194,
        446,
        211
      ],
      "score": 0.9922616481781006
    },
    {
