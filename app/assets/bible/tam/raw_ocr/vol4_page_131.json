        544,
        143,
        804,
        162
      ],
      "score": 0.991112232208252
    },
    {
      "text": "despues me volvereis á ver.",
      "box": [
        75,
        158,
        246,
        177
      ],
      "score": 0.9994823336601257
    },
    {
